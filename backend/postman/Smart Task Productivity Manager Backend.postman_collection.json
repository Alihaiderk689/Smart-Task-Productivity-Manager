        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"email\": \"test2@example.com\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/signup/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "signup"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) pm.environment.set('accessToken', jsonData.access);",
                  "if (jsonData.refresh) pm.environment.set('refreshToken', jsonData.refresh);",
                  "if (jsonData.user && jsonData.user.email) pm.environment.set('userEmail', jsonData.user.email);"
                ]
              }
            }
          ]
        },
